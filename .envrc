  # Hermetic toolchains on PATH via bazel_env.
  # Regenerate after toolchain changes with: bazel run //tools:bazel_env

  # watch_file — direnv reloads .envrc when this directory's contents change. Means when bazel run //tools:bazel_env regenerates the bin tree
  # (e.g., after a Rust version bump), direnv reacts automatically.
  watch_file bazel-out/bazel_env-opt/bin/tools/bazel_env/bin
  # PATH_add — straightforward; the bin tree lives at a stable, conventional path that bazel_env always uses
  # (bazel-out/bazel_env-opt/bin/tools/<name>/bin, where <name> matches the rule's name attr).
  # No bazel build, no cquery, no symlinks, no heredoc scripts. All the path-resolution and wrapper-invocation gunk is the ruleset's problem
  #now.
  PATH_add bazel-out/bazel_env-opt/bin/tools/bazel_env/bin

  if [[ ! -d bazel-out/bazel_env-opt/bin/tools/bazel_env/bin ]]; then
  # log_error if the dir is missing — direnv's friendly error helper. Without this, a fresh clone would silently fall back to host cargo and
  # confuse the developer. Failing loudly with the regen command is the polite move.
    log_error "ERROR[bazel_env.bzl]: Run 'bazel run //tools:bazel_env' to materialize the toolchain bin tree."
  fi

